{
  "name": "resume-analyzer-job-matcher",
  "version": "1.0.0",
  "description": "Free-first resume analyzer and job matcher with parsing, OCR fallback hooks, structured logging, and robust error handling.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "dev:client": "vite --config client/vite.config.js",
    "build:client": "vite build --config client/vite.config.js",
    "start": "node src/server.js",
    "lint": "node -e \"console.log('No linter configured yet')\"",
    "check": "node --check src/server.js"
  },
  "keywords": [
    "resume",
    "matcher",
    "n8n",
    "ollama",
    "ocr",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@netlify/functions": "^3.1.5",
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "mammoth": "^1.9.0",
    "multer": "^2.0.0",
    "pdf-parse": "^1.1.1",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "serverless-http": "^3.2.0",
    "tesseract.js": "^6.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "nodemon": "^3.1.9",
    "pino-pretty": "^13.0.0",
    "vite": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
